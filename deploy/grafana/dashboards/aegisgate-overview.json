{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(aegisgate_requests_total[1m])",
          "legendFormat": "{{model}} ({{status}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      }
    },
    {
      "title": "Active Connections",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "aegisgate_active_connections",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "thresholds": { "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 50 },
          { "color": "red", "value": 100 }
        ]}},
        "overrides": []
      }
    },
    {
      "title": "Cache Hit Rate",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "rate(aegisgate_cache_hits_total[5m]) / (rate(aegisgate_requests_total[5m]) + 1e-10)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": { "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 0.3 },
            { "color": "green", "value": 0.6 }
          ]}
        },
        "overrides": []
      }
    },
    {
      "title": "Request Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, rate(aegisgate_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(aegisgate_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(aegisgate_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      }
    },
    {
      "title": "Rate Limited / Guardrail Blocked",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "rate(aegisgate_rate_limited_total[1m])",
          "legendFormat": "rate_limited",
          "refId": "A"
        },
        {
          "expr": "rate(aegisgate_guardrail_blocks_total[1m])",
          "legendFormat": "guardrail_blocked",
          "refId": "B"
        },
        {
          "expr": "rate(aegisgate_fallback_total[1m])",
          "legendFormat": "fallback",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" },
        "overrides": []
      }
    },
    {
      "title": "Token Throughput",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "rate(aegisgate_tokens_total[1m])",
          "legendFormat": "tokens/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" },
        "overrides": []
      }
    },
    {
      "title": "Trace Search",
      "description": "Search traces by service and operation in Tempo",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceqlSearch",
          "limit": 20,
          "filters": [
            { "id": "service-name", "tag": "service.name", "operator": "=", "value": ["aegisgate"], "scope": "resource" }
          ],
          "refId": "A"
        }
      ]
    },
    {
      "title": "Request Duration by Route (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(aegisgate_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 latency",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      }
    },
    {
      "title": "Upstream Model Latency (p50/p95/p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(aegisgate_upstream_duration_seconds_bucket[5m])) by (le, model))",
          "legendFormat": "{{model}} p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(aegisgate_upstream_duration_seconds_bucket[5m])) by (le, model))",
          "legendFormat": "{{model}} p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(aegisgate_upstream_duration_seconds_bucket[5m])) by (le, model))",
          "legendFormat": "{{model}} p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["aegisgate"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "AegisGate Overview",
  "uid": "aegisgate-overview",
  "version": 1
}
