# AegisGate Showcase App — 环境变量示例
# 复制为 .env 并填入真实值。切勿把真实 Key 提交到版本控制。

# AegisGate 网关地址（Demo 后端经此接入大模型）
AEGISGATE_BASE_URL=http://localhost:8080

# AegisGate API Key（由 AegisGate 签发；模型 Provider Key 配在 AegisGate 侧，Demo 不持有）
AEGISGATE_API_KEY=replace-with-your-aegisgate-api-key

# 默认模型（需为支持 Function-Calling 的模型，如 gpt-4o-mini / deepseek-chat）
SHOWCASE_MODEL=gpt-4o-mini

# 可选：备用模型（演示智能路由 / fallback）
SHOWCASE_FALLBACK_MODEL=gpt-4o

# 后端监听端口
PORT=8090

# 允许的前端来源（CORS）
SHOWCASE_CORS_ORIGIN=http://localhost:5173
